<?xml version="1.0" encoding="UTF-8"?>
<interface domain="moniuszko">
    <template class="MyGtkAppWindow" parent="AdwApplicationWindow">
        <signal name="close_request" handler="handle_close_request" swapped="true"/>

        <property name="title">Moniuszko</property>
        <property name="content">
            <object class="AdwToolbarView">
                <child type="top">
                    <object class="AdwHeaderBar">
                        <child type="start">
                            <object class="GtkMenuButton">
                                <property name="menu_model">
                                    <menu>
                                        <section>
                                            <attribute name="label" translatable="yes">menu-playlist</attribute>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-new</attribute>
                                                <attribute name="action">playlist-new</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-save</attribute>
                                                <attribute name="action">playlist-save-to-file</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-load</attribute>
                                                <attribute name="action">playlist-load-from-file</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-undo</attribute>
                                                <attribute name="action">current-playlist-undo</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-redo</attribute>
                                                <attribute name="action">current-playlist-redo</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label" translatable="yes">menu-remove-selected-from-playlist</attribute>
                                                <attribute
                                                        name="action">current-playlist-delete-selected</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label"
                                                           translatable="yes">menu-clear-playlist</attribute>
                                                <attribute name="action">current-playlist-clear</attribute>
                                            </item>
                                        </section>
                                        <section>
                                            <attribute name="label" translatable="yes">menu-program</attribute>
                                            <item>
                                                <attribute name="label" translatable="yes">menu-config</attribute>
                                                <attribute name="action">config</attribute>
                                            </item>
                                            <item>
                                                <attribute name="label" translatable="yes">menu-quit</attribute>
                                                <attribute name="action">quit</attribute>
                                            </item>
                                        </section>
                                    </menu>
                                </property>
                            </object>
                        </child>
                    </object>
                </child>

                <property name="content">
                    <object class="GtkPaned">
                        <property name="orientation">horizontal</property>
                        <property name="position">512</property>

                        <child type="start">
                            <object class="GtkNotebook">
                                <property name="show-border">false</property>
                                <child>
                                    <object class="InfoPanel" id="info_panel">
                                        <property name="current" bind-source="playback" bind-property="current"
                                                  bind-flags="sync-create"/>
                                    </object>
                                </child>
                                <child type="tab">
                                    <object class="GtkLabel">
                                        <property name="label" translatable="yes">tab-info</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="MediaPanel" id="media_panel_music">
                                        <signal name="activate" handler="handle_library_activate" swapped="true"/>
                                        <signal name="refresh" handler="handle_refresh" swapped="true"/>

                                        <property name="subdatabase">music</property>
                                    </object>
                                </child>
                                <child type="tab">
                                    <object class="GtkLabel">
                                        <property name="label" translatable="yes">tab-music</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="MediaPanel" id="media_panel_books">
                                        <signal name="activate" handler="handle_library_activate" swapped="true"/>
                                        <signal name="refresh" handler="handle_refresh" swapped="true"/>

                                        <property name="subdatabase">books</property>
                                    </object>
                                </child>
                                <child type="tab">
                                    <object class="GtkLabel">
                                        <property name="label" translatable="yes">tab-books</property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child type="end">
                            <object class="GtkBox">
                                <property name="orientation">vertical</property>

                                <child>
                                    <object class="PlaylistPanel" id="playlist_panel">
                                        <property name="vexpand">true</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="PlayerUi" id="player">
                                        <signal name="next_track"
                                                handler="handle_next_track"
                                                swapped="true"/>
                                        <signal name="play_pause"
                                                handler="handle_play_pause"
                                                swapped="true"/>
                                        <signal name="previous_track"
                                                handler="handle_previous_track"
                                                swapped="true"/>

                                        <property name="playback_state">
                                            <object class="PlaybackState" id="playback">
                                                <signal name="ended"
                                                        handler="handle_ended"
                                                        swapped="true"/>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </property>
            </object>
        </property>
    </template>
</interface>
